@model List<CategoryAvgPriceChartDto>

<div class="col-xl-4">
    <div class="dash-card">
        <div class="dash-card-header">
            <div>
                <div class="section-title">Kategori Ortalama Fiyatları</div>
                <div class="section-sub">Aktif kategoriler</div>
            </div>
        </div>
        <div class="dash-card-body">
            <div class="d-flex align-items-center gap-3">
                
                <div class="chart-wrap" style="height:220px; width:140px; flex-shrink:0;">
                    <canvas id="pieChart"></canvas>
                </div>

                <div class="d-flex flex-column gap-1 flex-grow-1" style="font-size:12px;" id="pieChartLegend">
                    @{
                        var colors = new[] { "#e6a03c", "#3b82f6", "#22c55e", "#8b5cf6", "#14b8a6", "#ef4444", "#f59e0b", "#9b59b6", "#7f8c8d" };
                        for (int i = 0; i < Model.Count; i++)
                        {
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span style="width:10px;height:10px;border-radius:3px;background:@colors[i % colors.Length];display:inline-block;flex-shrink:0;"></span>
                                    <span class="text-truncate" style="max-width: 80px;">@Model[i].CategoryName</span>
                                </div>
                                <span style="font-weight:700;color:var(--text);">₺@Model[i].AvgPrice.ToString("F2")</span>
                            </div>
                        }
                    }
                </div>

            </div>
        </div>
    </div>

    <script>
            window.pieChartLabels = [@Html.Raw(string.Join(",", Model.Select(x => $"\"{x.CategoryName}\"")))];
            window.pieChartData   = [@Html.Raw(string.Join(",", Model.Select(x => x.AvgPrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))))];
    </script>
</div>